#define WIFI_PASSWORD "YOUR_PASSWORD_HERE"

#define MQTT_BROKER_IP "YOUR_MQTT_BROKER_IP"
#define MQTT_BROKER_PORT YOUR_MQTT_BROKER_PORT

/*
 * 統一命名空間：預設會組出
 *   iiot/<MQTT_SITE>/<MQTT_CLIENT_ID>/telemetry
 *   iiot/<MQTT_SITE>/<MQTT_CLIENT_ID>/status
 *   iiot/<MQTT_SITE>/<MQTT_CLIENT_ID>/ui-events
 * 完整規則見 include/mqtt_topics.h；亦可於下方覆寫各別 topic 字串。
 */
#define MQTT_NAMESPACE_PREFIX "iiot"
#define MQTT_SITE "default"
#define MQTT_CLIENT_ID "YOUR_MQTT_CLIENT_ID"

/* 選填：取消註解並寫入完整路徑時，會覆寫上方自動組出的 topic */

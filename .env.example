# 範本：複製為 .env 後依環境填入實際值（勿將含密碼的 .env 提交至版本庫）。
# Copy to .env and fill in real values. Do not commit secrets.

# For docker-compose.yml file create image tag use.
PROJECT_NAME=iot_monitoring_system_dotnet
CONTAINER_AUTHOR=your_dockerhub_or_registry_user
ENV_FILE_PATH=./.env

# For docker services host common bridge network.
NETWORK_NAME=iot_monitoring_system_dotnet
MONITOR_SYSTEM_SUBNET=172.95.26.0/24
MONITOR_SYSTEM_GATEWAY=172.95.26.1

# Nginx (HTTPS 終止、React 靜態、/api 反向代理至 backend_api)
# 基礎環境版本 (用於 Dockerfile FROM)
NGINX_BASE_VERSION=1.27-alpine
NODE_BASE_VERSION=20-alpine
FRONTEND_APP_VERSION=1.0.0
NGINX_HOST_IP=172.95.26.6
NGINX_HTTP_OUTSIDE_PORT=80
NGINX_HTTPS_OUTSIDE_PORT=443
NGINX_HTTP_INSIDE_PORT=80
NGINX_HTTPS_INSIDE_PORT=443
# NGINX_CERTS_DIR=local
NGINX_CERTS_DIR=server

# Backend API
BACKEND_API_HOST_IP=172.95.26.5
BACKEND_API_OUTSIDE_PORT=5163
# 須與 conf/nginx/default.conf 之 upstream（backend_api:埠）及 Dockerfile 預設一致
BACKEND_API_INSIDE_PORT=5163
# 與 docker-compose 中 ASPNETCORE_URLS=http://+:${BACKEND_API_INSIDE_PORT} 對齊
BACKEND_API_ASPNETCORE_ENVIRONMENT=Production
BACKEND_API_TIME_ZONE=Asia/Taipei
BACKEND_API_VERSION=1.0.0
BACKEND_API_MOSQUITTO_HOST_NAME=mqtt_broker
BACKEND_API_DATABASE_NAME=pico2wh_test
# 對應 EF Core / appsettings 之 Database:DefaultSchema（PostgreSQL schema 名稱）
BACKEND_API_DATABASE_DEFAULT_SCHEMA=dev
BACKEND_API_GROUP_ID=1001
# JWT 對稱簽章金鑰（UTF-8 至少 32 字元）；須與 appsettings 之 Jwt:SigningKey 語意相同，由環境覆寫
BACKEND_API_JWT_SIGNING_KEY=CHANGE_ME_DEV_ONLY_MIN_32_CHARS_LONG_SECRET_KEY!!

# Mosquitto
MOSQUITTO_VERSION=latest
MOSQUITTO_HOST_IP=172.95.26.4
# MQTT Standard (Pico 2 WH 採集端)
MOSQUITTO_OUTSIDE_PORT=1883
MOSQUITTO_INSIDE_PORT=1883
# MQTT TLS (Pico 2 WH 安全傳輸端)
MOSQUITTO_TLS_OUTSIDE_PORT=8883
MOSQUITTO_TLS_INSIDE_PORT=8883
# MQTT WebSocket (React Dashboard 開發環境)
MOSQUITTO_WEBSOCKET_OUTSIDE_PORT=9001
MOSQUITTO_WEBSOCKET_INSIDE_PORT=9001
# MQTT WSS (React Dashboard 生產環境/HTTPS)
MOSQUITTO_HTTPS_WEBSOCKET_OUTSIDE_PORT=9002
MOSQUITTO_HTTPS_WEBSOCKET_INSIDE_PORT=9002
MOSQUITTO_TIME_ZONE=Asia/Taipei
# 請改為強密碼；須與 Mosquitto 設定、後端與韌體連線設定一致
MOSQUITTO_USERNAME=mqtt_user
MOSQUITTO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MOSQUITTO_LOGFILENAME=/mosquitto/log/mosquitto.log
# MOSQUITTO_CERTS_DIR=local
MOSQUITTO_CERTS_DIR=server

# PostgreSQL
POSTGRES_TIME_ZONE=Asia/Taipei
POSTGRES_LANG_NAME=en_US.utf8
POSTGRES_LANG_INPUTFILE=en_US
POSTGRES_LANG_CHARMAP=UTF-8
POSTGRES_VERSION=18.3
DATABASE_HOST=postgresql
POSTGRES_DB=postgres
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PGDATA=/var/lib/postgresql/data
POSTGRES_DATA_BACKUP_PATH=/home/pgdata_backup
POSTGRES_HOST_IP=172.95.26.2
POSTGRES_OUTSIDE_PORT=5432
POSTGRES_INSIDE_PORT=5432

# PostgreSQL Adminer
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PGADMIN_HOST_IP=172.95.26.3
PGADMIN_OUTSIDE_PORT=5533
PGADMIN_INSIDE_PORT=80
POSTGRES_ADMINER_VERSION=9.14

# Cloudflare Tunnel（選用；docker compose --profile cloudflare）
# 於 Zero Trust → Networks → Tunnels 建立 Tunnel，複製「Install connector」之 token。
CLOUDFLARED_VERSION=latest
CLOUDFLARED_HOST_IP=172.95.26.7
TUNNEL_TOKEN=
